# Environment
ENV=development
DEBUG=true

# API
API_VERSION=3.0.0
API_TITLE=ChantierDoc Document Processing API

# Mistral (Optional - used only for health check /api/v1/health/ready)
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_OCR_TIMEOUT=60

# Authentication - API Key for n8n workflow (REQUIRED)
# IMPORTANT: Generate a secure random key for production!
# Example: openssl rand -hex 32
API_SECRET_KEY=your-secure-api-key-replace-this-in-production

# Timeouts (en secondes)
REQUEST_TIMEOUT=180
PROCESSING_TIMEOUT=120
ENRICHMENT_TIMEOUT=30

# Security - CORS Origins (JSON array format)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
ALLOWED_HOSTS=["localhost","127.0.0.1"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10

# Logging
LOG_LEVEL=INFO
